<!DOCTYPE html>
<html lang="sw">
<head>
    <meta charset="UTF-8">
    <title>Admin Panel | Hasheem Gaming</title>
    <style>
        body { background: #0f172a; color: white; font-family: sans-serif; padding: 20px; }
        .admin-box { background: #1e293b; padding: 30px; border-radius: 15px; max-width: 500px; margin: 0 auto; }
        input { width: 100%; padding: 12px; margin: 10px 0; border-radius: 8px; border: 1px solid #334155; background: #0f172a; color: white; box-sizing: border-box; }
        button { width: 100%; padding: 15px; background: #22c55e; border: none; color: white; font-weight: bold; border-radius: 8px; cursor: pointer; }
        .game-list { margin-top: 40px; max-width: 500px; margin-left: auto; margin-right: auto; }
        .game-item { background: #334155; padding: 15px; margin-bottom: 10px; border-radius: 10px; display: flex; justify-content: space-between; }
        .del-btn { background: #ef4444; border: none; color: white; padding: 5px 10px; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body>

<div class="admin-box">
    <h2>Admin Dashboard 🛠️</h2>
    <input type="text" id="gName" placeholder="Jina la Game">
    <input type="text" id="gImg" placeholder="Link ya Picha (URL)">
    <input type="text" id="gLink" placeholder="Link ya MediaFire/Mega">
    <button onclick="addGame()">ONGEZA GAME SOKONI</button>
</div>

<div class="game-list" id="adminList">
    </div>

<script>
    function addGame() {
        let name = document.getElementById('gName').value;
        let img = document.getElementById('gImg').value;
        let link = document.getElementById('gLink').value;

        if(!name || !link) return alert("Jaza jina na link!");

        let games = JSON.parse(localStorage.getItem('hasheem_database')) || [];
        games.push({ name, img, link });
        localStorage.setItem('hasheem_database', JSON.stringify(games));
        
        alert("Game Limehifadhiwa!");
        location.reload();
    }

    function showAdminList() {
        let games = JSON.parse(localStorage.getItem('hasheem_database')) || [];
        let listArea = document.getElementById('adminList');
        listArea.innerHTML = '<h3>Magame Yaliyopo:</h3>' + games.map((g, index) => `
            <div class="game-item">
                <span>${g.name}</span>
                <button class="del-btn" onclick="removeGame(${index})">Futa</button>
            </div>
        `).join('');
    }

    function removeGame(index) {
        let games = JSON.parse(localStorage.getItem('hasheem_database')) || [];
        games.splice(index, 1);
        localStorage.setItem('hasheem_database', JSON.stringify(games));
        showAdminList();
    }

    window.onload = showAdminList;
</script>
</body>
</html>
